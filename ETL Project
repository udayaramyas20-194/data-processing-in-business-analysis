        "# MODULE 4: BASIC SENTIMENT MODEL\n",
        "# ==========================================\n",
        "positive = [\"love\",\"amazing\",\"best\",\"happy\",\"excellent\",\"fantastic\",\"great\",\"wonderful\"]\n",
        "negative = [\"hate\",\"worst\",\"bad\",\"terrible\",\"poor\",\"slow\",\"crashing\",\"refund\"]\n",
        "\n",
        "def sentiment_model(text):\n",
        "    score = 0\n",
        "    for w in positive:\n",
        "        if w in text:\n",
        "            score += 1\n",
        "    for w in negative:\n",
        "        if w in text:\n",
        "            score -= 1\n",
        "    if score > 0:\n",
        "        return \"positive\"\n",
        "    elif score < 0:\n",
        "        return \"negative\"\n",
        "    else:\n",
        "        return \"neutral\"\n",
        "\n",
        "df[\"predicted\"] = df[\"tweet\"].apply(sentiment_model)"
      ],
      "metadata": {
